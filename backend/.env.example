PORT=4010
NODE_ENV=development

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=apex_linkedin_ops

JWT_ACCESS_SECRET=change-me-to-a-long-random-string
JWT_REFRESH_SECRET=change-me-too
# Access token lifetime (seconds). 28800 = 8 hours
JWT_ACCESS_TTL_SECONDS=28800

# React dev server (Vite default 5173)
CLIENT_URL=http://localhost:5173

UPLOAD_DIR=./uploads/cards

CRON_SECRET=change-me-cron-secret

# Google Gemini — AI captions (Google AI Studio)
# Optional: override from Admin → AI Config (no redeploy). Env is fallback until saved in DB.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# OpenAI — alternative AI captions (https://platform.openai.com/api-keys)
# Set AI_PROVIDER=openai to use OpenAI only, or leave "auto" to try Gemini then OpenAI
# Keys can also be updated in Admin → AI Config without redeploying.
AI_PROVIDER=auto
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Ollama — self-hosted local AI (comma-separated URLs supported)
OLLAMA_BASE_URL=http://10.100.0.1:11434,http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1:8b

# Ollama Hosted — advanced configuration for hosted Ollama instances
# These settings apply when using a hosted Ollama server with RAG and embedding features
DEFAULT_AI_MODEL=qwen2.5:14b-instruct
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIM=768
QUESTION_GENERATION_MODEL=qwen2.5:14b-instruct
ANALYSIS_AI_MODEL=qwen2.5:14b-instruct
OLLAMA_NUM_GPU=0
OLLAMA_NUM_CTX=8192
OLLAMA_CHAT_TIMEOUT_MS=900000
RAG_TOP_K=5

LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:5173/api/linkedin/callback
